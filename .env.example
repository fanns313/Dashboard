# ========================================
# Proxmox Configuration
# ========================================
PROXMOX_HOST=https://YOUR_PROXMOX_IP:8006
PROXMOX_TOKEN_ID=root@pam!YOUR_TOKEN_NAME
PROXMOX_TOKEN_SECRET=your-token-secret-here
PROXMOX_NODE=pve
# Set to "true" if Proxmox uses self-signed SSL cert
PROXMOX_ALLOW_SELF_SIGNED=true

# ========================================
# Keycloak Configuration
# ========================================
KEYCLOAK_URL=https://your-keycloak-domain.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=your-client-secret

# ========================================
# NextAuth / Auth.js Configuration
# ========================================
AUTH_URL=https://your-dashboard-domain.com
AUTH_SECRET=generate-a-random-secret-here
AUTH_TRUST_HOST=true

# ========================================
# App Configuration
# ========================================
# Polling interval for VM status updates (in ms)
NEXT_PUBLIC_POLL_INTERVAL=5000
